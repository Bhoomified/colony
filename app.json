{
  "expo": {
    "name": "Colony",
    "slug": "colony",
    "scheme": "colony",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#8B1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.colony.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8B1A1A"
      },
      "package": "com.colony.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B1A1A"
        }
      ],
      "expo-status-bar",
      "expo-splash-screen",
      "expo-secure-store"
    ]
  }
}
